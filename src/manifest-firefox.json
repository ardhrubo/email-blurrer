{
  "manifest_version": 3,
  "name": "Email Blurrer",
  "version": "1.1.0",
  "description": "Hides or blurs email addresses on web pages for privacy.",
  "permissions": ["storage"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "toggle-protection": {
      "suggested_key": {
        "default": "Alt+Shift+H",
        "mac": "Ctrl+Shift+H"
      },
      "description": "Toggle Email Blurrer protection"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/constants.js", "content/masking.js", "content/runtime.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_title": "Email Blurrer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
